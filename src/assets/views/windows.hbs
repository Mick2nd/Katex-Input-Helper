<!-- The Custom Equations dialog -->
<div id="wf_CUSTOM_EQUATIONS_MORE" class="easyui-dialog" iconcls="icon-equation" 
	data-options="closed:true,modal:false,shadow:false,resizable:true,collapsible:true,buttons:'#btCUSTOM_EQUATIONS_BUTTONS'"
	title="<span id='wf_CUSTOM_EQUATIONS_MORE_TITLE' class='custom-equations rtl-title-withicon' locate='CUSTOM_EQUATIONS'></span>"
>
	<div id="CUSTOM_EQUATIONS_LAYOUT" class="easyui-layout">
		<div data-options="region:'west',split:true" style="width: 25%;">
			<ul id="categories" class="easyui-tree" data-options="dropAccept:'.datagrid-div'">
			</ul>
			
			<div id="treeMenu" class="easyui-menu" data-options="minWidth:160">
				<div id="mAppendFolder" class="custom-equations easyui-tooltip" data-options="iconCls:'icon-add'"
					title="<span locate='TTAPPENDFOLDER'>Append Folder</span>">
					<span class="custom-equations" locate="APPENDFOLDER">Append Folder</span>
				</div>
				<div id="mAppendCategory" class="custom-equations easyui-tooltip" data-options="iconCls:'icon-add'"
					title="<span locate='TTAPPENDCATEGORY'>Append Categroy</span>">
					<span class="custom-equations" locate="APPENDCATEGORY">Append Category</span>
				</div>
				<div id="mRemove" class="custom-equations easyui-tooltip" data-options="iconCls:'icon-remove'"
					title="<span locate='TTREMOVEFOLDER'>REMOVE</span>" >
					<span class="custom-equations" locate="REMOVE">Remove</span>
				</div>
			</div>
			<div id="treeMenuLeaf" class="easyui-menu" data-options="minWidth:160">
				<div id="mRemoveLeaf" class="custom-equations easyui-tooltip" data-options="iconCls:'icon-remove'"
					title="<span locate='TTREMOVECATEGORY'>REMOVE</span>" >
					<span class="custom-equations" locate="REMOVE">Remove</span>
				</div>
				<div data-options="separator:true"></div>
				<div id="mCutPaste" class="custom-equations easyui-tooltip" data-options="iconCls:'icon-cut'"
					title="<span locate='TTCUTPASTE'>Cut &amp; Paste Equations</span>" >
					<span class="custom-equations" locate="CUTPASTE">Cut &amp; Paste Equations</span>
				</div>
			</div>
		</div>
		<div data-options="region:'center'" >
			<table id="customDatagrid" class="easyui-datagrid">
			    <thead>
			        <tr>
			        <!-- Without these entries data grid wouldn't work -->
			            <th class="custom-equations" data-options="field:'id',hidden:true">Id</th>
			            <th class="custom-equations" data-options="field:'title',editor:'text',width:'35%',sortable:true">Titel</th>
			            <th class="custom-equations" data-options="field:'formula',width:'60%'">Formel</th>
			        </tr>
			    </thead>
			    <tbody>
				</tbody>
			</table>
		</div>
	</div>
	<div id="btCUSTOM_EQUATIONS_BUTTONS" >
		{{> toggle id='toggle_btn_1' ttkey='TTREGION' text='' width='20' }}
		<a href="" id="btCUSTOM_EQUATIONS_ADD" class="easyui-linkbutton easyui-tooltip custom-equations" iconcls="icon-add"
			title="<span locate='TTADD'>ADD</span>" >
			<span class="custom-equations" locate="ADD">ADD</span>
		</a>
		<a href="" id="btCUSTOM_EQUATIONS_REMOVE" class="easyui-linkbutton easyui-tooltip custom-equations" iconcls="icon-remove"
			title="<span locate='TTREMOVE'>REMOVE</span>" >
			<span class="custom-equations" locate="REMOVE">REMOVE</span>
		</a>
		<a href="" id="btCUSTOM_EQUATIONS_LOAD" class="easyui-linkbutton easyui-tooltip custom-equations" iconcls="icon-open"
			title="<span locate='TTLOAD'>LOAD</span>" >
			<span class="custom-equations" locate="LOAD">LOAD</span>
		</a>
		<a href="" id="btCUSTOM_EQUATIONS_SAVE" class="easyui-linkbutton easyui-tooltip custom-equations" iconcls="icon-save"
			title="<span locate='TTSAVE'>SAVE</span>" >
			<span class="custom-equations" locate="SAVE">SAVE</span>
		</a>
	</div>
	<input type="file" id="fOPEN_CUSTOM_EQUATIONS" class="invisible" />
	<a id="fSAVE_CUSTOM_EQUATIONS" href="" ></a>
</div>

