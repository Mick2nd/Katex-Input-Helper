
<!-- Dialogs and Windows
	 This content is common to all screen sizes. 
-->

<!-- The Editor Parameters dialog -->
<div id="wEDITOR_PARAMETERS" class="easyui-dialog" iconcls="icon-option" data-options="closed:true,modal:true,buttons:'#btEDITOR_PARAMETERS',resizable:true"
	title="<span locate='EDITOR_PARAMETERS' class='rtl-title-withicon'></span>">
	<form id="formEDITOR_PARAMETERS" action="#" method="post">
		<fieldset>
			<legend><span locate='PERSISTENCE'></span></legend>
			<div>
				<input type="checkbox" name="persistWindowPositions" id="persistWindowPositions" /> 
				<label for="persistWindowPositions"><span locate='PERSIST_WINDOW_POSITIONS'></span></label>
			</div>
			<div>
				<input type="checkbox" name="persistEquations" id="persistEquations" /> 
				<label for="persistEquations"><span locate="PERSIST_EQUATIONS"></span></label>
			</div>
		</fieldset>
		<hr />
		<fieldset>
			<legend>
				<span locate='UPDATE'></span>
			</legend>
			<div>
				<input type="checkbox" name="menuupdateType" id="menuupdateType" />
				<label for="menuupdateType"><span locate='MENU_UPDATE'></span></label>
			</div>
			<div>
				<input type="checkbox" name="autoupdateType" id="autoupdateType" />
				<label for="autoupdateType"><span locate='AUTO_UPDATE'></span></label>
			</div>
			<div>
				<input name="autoUpdateTime" id="autoUpdateTime" size="4" maxlength="4" /> 
				<label for="autoUpdateTime"><span locate='UPDATE_INTERVAL'></span></label>
			</div>
		</fieldset>
		<hr />
		<fieldset>
			<legend>
				<span locate="RESET"></span>
			</legend>
			<a href="#" id="btRESET_WINDOW_POSITIONS" class="easyui-linkbutton">
				<span locate="RESET_WINDOW_POSITIONS"></span>
			</a>
		</fieldset>				
	</form>
	<div id="btEDITOR_PARAMETERS">
		<a href="" id="btEDITOR_PARAMETERS_CLOSE" class="easyui-linkbutton" iconcls="icon-cancel">
			<span locate="CLOSE"></span>
		</a>
	</div>
</div>

<!-- The Language Choice dialog -->
<div class="easyui-dialog" iconcls="icon-language" data-options="closed:true,modal:true,buttons:'#btLANGUAGE_CHOISE',resizable:true"
	id="wLANGUAGE_CHOISE" title="<span locate='LANGUAGE_CHOISE' class='rtl-title-withicon'></span>" >
	<form id="formLANGUAGE_CHOISE" action="#" method="post">
	</form>
	<div id="btLANGUAGE_CHOISE">
		<a href="" id="btLANGUAGE_CHOISE_CLOSE" class="easyui-linkbutton" iconcls="icon-cancel">
			<span locate="CLOSE"></span>
		</a>
	</div>
</div>

<!-- The Style Choice dialog -->
<div class="easyui-dialog" iconcls="icon-style" data-options="closed:true,modal:true,buttons:'#btSTYLE_CHOISE',resizable:true"
	id="wSTYLE_CHOISE" title="<span locate='STYLE_CHOISE' class='rtl-title-withicon'></span>" >
	<form id="formSTYLE_CHOISE" action="#" method="post">
		<fieldset dir='ltr'>
			<input type="radio" name="style" id="aguas_style" value="aguas" /> 
			<label for="aguas_style">&laquo; Aguas &raquo;</label> <br />
			
			<input type="radio" name="style" id="gray_style" value="gray" /> 
			<label for="gray_style">&laquo; Gray &raquo;</label> <br />
			
			<input type="radio" name="style" id="black_style" value="black" /> 
			<label for="black_style">&laquo; Black &raquo;</label> <br />
			
			<input type="radio" name="style" id="bootstrap_style" value="bootstrap" /> 
			<label for="bootstrap_style">&laquo; Bootstrap &raquo;</label> <br />
			
			<input type="radio" name="style" id="metro_style" value="metro" /> 
			<label for="metro_style">&laquo; Metro &raquo;</label>
		</fieldset>
	</form>
	<div id="btSTYLE_CHOISE">
		<a href="" id="btSTYLE_CHOISE_CLOSE" class="easyui-linkbutton" iconcls="icon-cancel"><span
				locate="CLOSE"></span></a>
	</div>
</div>

<!-- The Matrix dialog -->
<div id="wMATRIX" class="easyui-dialog" iconcls="icon-matrix" data-options="cls:'mat',closed:true,modal:true,buttons:'#btMATRIX',resizable:true"
	title="<span locate='MATRIX' class='rtl-title-withicon'></span>" >
	<form id="formMATRIX" name="formMATRIX" action="#" method="post">
		<table id="tableMATRIX" dir="ltr">
			<tr>
				<td colspan="2">&nbsp;</td>
				<td>
					<input name="colsMATRIX" id="colsMATRIX" size="1" maxlength="2" value="3" />
				</td>
				<td>&nbsp;</td>
			</tr>
			<tr>
				<td><input name="rowsMATRIX" id="rowsMATRIX" size="1" maxlength="2" value="3" /></td>
				<td><select name="leftbracketMATRIX">
						<option value="(" selected="selected">(</option>
						<option value="[">[</option>
						<option value="{">{</option>
						<option value="(:">&lt;</option>
						<option value="|">|</option>
						<option value="||">||</option>
						<option value="{:">&nbsp;</option>
						<option value=")">)</option>
						<option value="]">]</option>
						<option value="}">}</option>
						<option value=":)">&gt;</option>
					</select></td>
				<td>
					<div id="showMATRIX"></div>
				</td>
				<td><select name="rightbracketMATRIX">
						<option value=")" selected="selected">)</option>
						<option value="]">]</option>
						<option value="}">}</option>
						<option value=":)">&gt;</option>
						<option value="|">|</option>
						<option value="||">||</option>
						<option value=":}">&nbsp;</option>
						<option value="(">(</option>
						<option value="[">[</option>
						<option value="{">{</option>
						<option value="(:">&lt;</option>
					</select>
				</td>
			</tr>
		</table>
	</form>
	<div id="btMATRIX">
		<a href="" id="btMATRIX_SET" class="easyui-linkbutton" iconcls="icon-ok">
			<span locate="SET_IN_EDITOR"></span>
		</a> 
		<a href="" id="btMATRIX_CLOSE" class="easyui-linkbutton" iconcls="icon-cancel">
			<span locate="CLOSE"></span>
		</a>
	</div>
</div>

